[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.1
reloadable = true

[icons]
MovableWindow = "res://sprites/flowery.svg"

[libraries]
linux.debug.x86_64 =     "res://../rust/target/debug/libflowery_extensions.so"
linux.release.x86_64 =   "res://../rust/target/release/libflowery_extensions.so"
windows.debug.x86_64 =   "res://../rust/target/debug/flowery_extensions.dll"
windows.release.x86_64 = "res://../rust/target/release/flowery_extensions.dll"
macos.debug =            "res://../rust/target/debug/libflowery_extensions.dylib"
macos.release =          "res://../rust/target/release/libflowery_extensions.dylib"
macos.debug.arm64 =      "res://../rust/target/debug/libflowery_extensions.dylib"
macos.release.arm64 =    "res://../rust/target/release/libflowery_extensions.dylib"